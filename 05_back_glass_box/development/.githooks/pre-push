#!/bin/sh

# Get the directory where the script is located
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PROJECT_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

cd "$PROJECT_ROOT" || {
    echo "ERROR: Could not change to project root $PROJECT_ROOT"
    exit 1
}

echo "Running pre-push hook via make..."
make check || {
    echo "ERROR: pre-push checks failed. Please fix the issues before pushing."
    exit 1
}

echo "All checks passed. Pushing changes..."
exit 0
